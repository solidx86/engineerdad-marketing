# Dependencies
node_modules/

# Build output
dist/
*.tsbuildinfo

# Local-only data — live PG volume, generated assets, DB dumps, render scratch.
# Nothing under data/ ships publicly (ADR-025 Postgres-only; E-029 PG volume;
# E2E walk pg_dumps; static-renderer/asset-store output). Keep only the postgres
# mount-point placeholder so docker's bind-mount path exists on a fresh clone.
data/*
!data/postgres/
data/postgres/*
!data/postgres/.gitkeep

# Test harness output for the static-asset worker (ADR-014).
# Used by `pnpm test:worker <fixture>`; transient.
tmp/test-output/

# Environment
.env
.env.local
.env.*.local

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Claude Code per-machine settings (agents/ and project settings.json are tracked)
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Next.js build artefacts
apps/*/.next/
apps/*/node_modules/

# Playwright artefacts (binary blobs, regenerated per run)
apps/*/test-results/
apps/*/playwright-report/
.playwright-mcp/

# Worktree dirs created by the EnterWorktree native tool — ephemeral local copies, never committed
.claude/worktrees/

# Corpus search index — pure build artefact, regenerated by /ingest-corpus; tracked it collides on every rebase
corpus/.index/
