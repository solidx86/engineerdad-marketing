    "@engineerdad/shared": "workspace:*",
    "@engineerdad/store": "workspace:*",
    "drizzle-orm": "^0.36.0",
    "postgres": "^3.4.5",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.28.0"
  }
