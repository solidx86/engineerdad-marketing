# Meta Marketing API
META_TOKEN=
AD_ACCOUNT_ID=
PIXEL_ID=
CAPI_TOKEN=

# Meta-paid distribute mode (ADR-015 amendment). api|manual — manual (the
# default) renders the webapp posting pack instead of creating Meta ads via the
# API; switch to api once Meta business verification unblocks ad creation.
META_PAID_MODE=manual

# CAPI test mode safety net (v1 only — production CAPI server deferred to v1.5).
# Grab from Meta Events Manager → Test Events tab. If absent, capi_send fails
# loudly rather than silently going to production.
META_CAPI_TEST_EVENT_CODE=

# Gemini image generation (E-004 image phase — billing must be enabled on the
# Google AI project; NO FREE TIER for image generation. Verified 2026-05-10.)
GEMINI_API_KEY=

# kie.ai video generation — DORMANT as of 2026-05-29 per the E-004 rescope
# (docs/superpowers/specs/2026-05-28-heygen-reel-pipeline-design.html). The
# Reel pipeline now uses HeyGen + static-renderer + packages/media-stitch;
# kie.ai / Veo 3 generative B-roll was retired (off-brand per the
# corpus/courses/brand-voice.md doctrine). Token may be removed in a
# future cleanup if no other consumer surfaces.
KIE_AI_TOKEN=

# Meta organic (IG Business + FB Page)
META_ORGANIC_PAGE_ID=
META_ORGANIC_IG_USER_ID=
META_ORGANIC_ACCESS_TOKEN=

# HeyGen — AI avatar renders for the Reel pipeline (E-004 / 2026-05-28
# heygen-reel-pipeline). Each Reel CreativeUnit issues ONE generate_video
# call against this account, so anything that activates the pipeline
# (EDOS_REEL_PIPELINE=on) consumes paid quota per Reel.
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=             # Shoo's trained Instant Avatar id (HeyGen dashboard → Avatars → Instant Avatar)
HEYGEN_VOICE_ID=              # English voice id (HeyGen dashboard → Voices); V1 ships EN only

# Reel pipeline opt-in switch — DEFAULT OFF. The Reel render path is gated
# behind this var to prevent accidental HeyGen credit burn. Set to the
# literal string "on" (case-sensitive) to enable; any other value, empty
# string, or unset leaves it disabled. When off, P1a-reels-prepare and
# the P2-render Reel branch emit nothing — the loop behaves as it did
# before activation (HG3 reviewer sees Reel rows with assetFiles=[]).
EDOS_REEL_PIPELINE=

# Whisper fallback for Reel scene-to-time alignment. Only invoked when
# HeyGen omits caption_url on a completed render (older account tiers).
# Path to a whisper.cpp ggml model file (e.g. ggml-base.en.bin); if unset,
# the reel-render-worker downgrades to proportional scene allocation and
# surfaces a warning in HG3.
WHISPER_MODEL_PATH=

# Cloudflare R2 asset store (F11 / E-007 MVP — public HTTPS host for static
# PNG assets that Meta Graph fetches when publishing image/carousel posts).
# asset-store uploads each PNG it writes locally to R2 under
# <run_id>/<variant_id>/<scene>.<ext>, then returns ASSET_STORE_PUBLIC_BASE +
# that key as the canonical URL. Endpoint URL is derived: it's always
# https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com.
#
# Set up:
#   1. Create R2 bucket → set its name in ASSET_STORE_R2_BUCKET.
#   2. R2 → Manage R2 API Tokens → create one with Object Read & Write,
#      scoped to that bucket only. The dialog shows Access Key ID (32-char hex)
#      and Secret Access Key (64-char hex) ONCE — copy both.
#   3. Connect a custom domain to the bucket (recommended) or enable the
#      r2.dev managed subdomain. That HTTPS base goes in ASSET_STORE_PUBLIC_BASE.
#
# When ASSET_STORE_R2_BUCKET is unset, asset-store falls back to file:// URLs
# (local-only). meta-organic / Meta Graph cannot fetch file:// — leaving these
# unset will block /distribute on the meta-organic channel.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
ASSET_STORE_R2_BUCKET=
ASSET_STORE_PUBLIC_BASE=

# Postgres (E-029)
DATABASE_URL=postgresql://engineerdad:engineerdad@localhost:5432/engineerdad
DATABASE_URL_TEST=postgresql://engineerdad:engineerdad@localhost:5432/engineerdad_test

# Review UI (E-029) — base URL of the Next.js human-gate app. The dev server
# port lives in apps/review-ui/package.json scripts; change both if you move it.
# Everything that constructs a review-UI link (posting-pack, agent prompts,
# Playwright config, server-action allowedOrigins) reads this — never hardcode.
REVIEW_UI_URL=http://localhost:3030

# Landing page URL for Meta ad creatives (default link_url in createAdCreative when link_url is not supplied)
LANDING_URL=https://engineerdad.my
